<RCC>
    <qresource prefix="/">
        <file alias="styles/Daylight.qss">resources/styles/Daylight.qss</file>
        <file alias="signatures/seed.json">resources/signatures/seed.json</file>
        <file alias="sql/schema.sql">resources/sql/schema.sql</file>
        <file alias="i18n/verax_en.qm">i18n/verax_en.qm</file>
        <file alias="i18n/verax_ar.qm">i18n/verax_ar.qm</file>
    </qresource>
    <qresource prefix="/assets">
        <file alias="logo.png">resources/assets/logo.png</file>
        <file alias="logo.ico">resources/assets/logo.ico</file>
        <file alias="logo.svg">resources/assets/logo.svg</file>
    </qresource>
</RCC>
