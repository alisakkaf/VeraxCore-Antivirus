    "engine_notes": {
        "PE.Structural": {
            "description": "Detects packed/encrypted/infected PE binaries even when their SHA-256 is unknown.",
            "detects": [
                "Named-infector sections: .floxif .flx .sality .sal .virut .vrt .rmnet .ramnit .parite .expiro .polip .mabezat .tenga .lamer .jeefo .hidrag .mydoom .bagle .neshta .viking .alman .induc .vetor .mikcer .mkc .nimnul .xpaj .patched",
                "Executable+writable (RWX) sections",
                "Section entropy > 7.5 on executable sections",
                "EP inside the last section",
                "Overlay larger than image",
                "Code-injection import combo (VirtualAllocEx + WriteProcessMemory + CreateRemoteThread)",
                "Anti-debug / evasion API surface",
                "Floxif: E9/FF25 EP hook to non-standard section (excluding known packers)",
                "Mikcer: EB/68+C3 EP redirect to executable section",
                "Sality: CALL $+5 / PUSHAD delta-offset at EP, RWX last section",
                "Virut: INT3+NOP+JMP / conditional JCC (0F 8x) polymorphic EP hook",
                "Ramnit: EP JMP to appended section with stored prologue recovery",
                "Neshta: ~41KB code cave in .text section with EP JMP to cave",
                "Expiro: CALL $+5; POP EBX/EAX delta-offset, multi-section RWX infection",
                "IAT hooks: import table entries pointing to suspicious/infector sections",
                "EP anomaly: non-standard prologue + cross-section JMP",
                "Code cave injection: executable code in section padding",
                "Overlay payload: suspicious data beyond last PE section"
            ]
        },
        "PE.CleanThreat": {
            "description": "Advanced repair engine for PE file infectors. Removes virus code and restores EXE/DLL to working state.",
            "capabilities": [
                "Backup: Creates .verax_bak before any modification",
                "Auto-Restore: Restores backup if repair fails verification",
                "Taskkill: Terminates processes using the infected file",
                "Full Permissions: Sets complete read/write/execute permissions",
                "Smart Prologue Recovery: Recovers original EP bytes from infector section (Ramnit/Floxif pattern)",
                "Section Wipe: Surgically removes infector-added sections with data shifting",
                "EP Restore: Restores original entry point prologue (x86: 558BEC/8BFF55/6Axx68, x64: 4883EC28/48895C24)",
                "Overlay Truncation: Removes appended data beyond PE image",
                "SizeOfImage Fix: Recalculates SizeOfImage after section removal",
                "Checksum Fix: Recalculates PE checksum",
                "Integrity Verify: Validates PE structure + re-scans post-repair",
                "Safe Repair: Never touches imports, exports, resources, relocations, TLS",
                "IAT Hook Detection: Validates import table integrity against section boundaries"
            ],
            "supported_families": [
                "Floxif (A-H, with byte sig EP detection)",
                "Mikcer (A-F, with byte sig EP detection)",
                "Sality (gen/AE/AT, CALL $+5 / PUSHAD detection)",
                "Ramnit (gen/A/B, stored prologue recovery)",
                "Rmnet (gen/A)",
                "Virut (gen/CE, conditional JCC / INT3+NOP+JMP detection)",
                "Neshta (code cave in .text detection)",
                "Parite (gen/B)",
                "Expiro (gen/T, CALL $+5; POP EBX / multi-section detection)",
                "Viking",
                "Alman",
                "Jeefo",
                "Hidrag",
                "Induc",
                "Vetor",
                "Nimnul (gen/A)",
                "Xpaj (gen/B)",
                "Mabezat",
                "Polip",
                "Lamer",
                "Patched",
                "Generic.EPHook (A/B, delta-offset patterns)",
                "Generic.CodeCave (A, JMP+NOP sled patterns)",
                "Generic.EPHook x64 (A)"
            ]
        }
    }
